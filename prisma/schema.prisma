  @@index([userId])
  @@index([expiresAt])
  @@index([consumedAt])
  @@index([revokedAt])
}

// One-time TOTP recovery/backup codes (AUDIT-20260613-041 #9). Codes are stored
// only as SHA-256 hashes; consumption is an atomic `updateMany ... where usedAt:null`
// (TOCTOU-safe, mirroring the magic-link redemption pattern).
model TwoFactorBackupCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, codeHash])
  @@index([userId, usedAt])
}

model Notification {
