  type        NotificationType
  title       String
  message     String?
  link        String?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())
  senderId    String?
  eventId     String?
  communityId String?
  // Optional FK → implicit onDelete: SetNull (notification kept, sender disowned, when the sender is removed). `eraseUserPersonalData` (AUDIT-20260613-028) nulls senderId; recipient-side rows cascade via the `user` relation below.
  sender      User?            @relation("Notification_senderIdToUser", fields: [senderId], references: [id])
  user        User             @relation("Notification_userIdToUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([isRead])
  @@index([userId])
  @@index([userId, isRead, createdAt])
}

