}

enum FeedReactionType {
  INSPIRED
  LEARNED
  CAN_HELP
  CAN_CONNECT
  WORTH_DEEPER_LISTENING
  REGENERATIVE
}

enum FeedAnnotationSource {
  AUTHOR
  VIEWER
}

model FeedComment {
  id               String                @id @default(cuid())
  postId           String
  parentId         String?
  content          String
  plainText        String?
  authorId         String
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  deletedAt        DateTime?
  // Required FK → implicit onDelete: Restrict. Comment survives account deletion; `eraseUserPersonalData` (AUDIT-20260613-028) anonymizes it in place (content → '[deleted]', deletedAt set) rather than cascading.
  author           User                  @relation(fields: [authorId], references: [id])
  parent           FeedComment?          @relation("FeedCommentToFeedComment", fields: [parentId], references: [id])
  replies          FeedComment[]         @relation("FeedCommentToFeedComment")
  post             FeedPost              @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentReactions FeedCommentReaction[]
  FeedMention      FeedMention[]

  @@index([authorId])
