model Invite {
  id             String       @id @default(cuid())
  code           String       @unique
  createdById    String
  recipientEmail String?
  recipientId    String?
  status         InviteStatus @default(CREATED)
  isDirect       Boolean      @default(false)
  profileType    ProfileType?
  emailSubject   String?
  resendCount    Int          @default(0)
  createdAt      DateTime     @default(now())
  sentAt         DateTime?
  openedAt       DateTime?
  acceptedAt     DateTime?
  expiresAt      DateTime
  revokedAt      DateTime?
  revokedById    String?
  revokeReason   String?
  lastActivityAt DateTime     @default(now())
  notes          String?
  // Required FK → implicit onDelete: Restrict. Restrict relies on `eraseUserPersonalData` (AUDIT-20260613-028) hard-deleting invites the user created before user deletion; no cascade declared.
  createdBy      User         @relation("Invite_createdByIdToUser", fields: [createdById], references: [id])
  // Optional FK → implicit onDelete: SetNull (invite kept, recipient disowned). `eraseUserPersonalData` (AUDIT-20260613-028) nulls recipientId + recipientEmail.
  recipient      User?        @relation("Invite_recipientIdToUser", fields: [recipientId], references: [id])
  // Optional FK → implicit onDelete: SetNull (invite kept, revoker disowned). `eraseUserPersonalData` (AUDIT-20260613-028) nulls revokedById + revokeReason.
  revokedBy      User?        @relation("Invite_revokedByIdToUser", fields: [revokedById], references: [id])

