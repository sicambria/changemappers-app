}

model FeedPost {
  id             String                  @id @default(cuid())
  content        String?
  plainText      String?
  /// Media attachments: `Array<{ type: 'image' | 'video'; url: string; alt?: string }>`. See `createPostSchema.attachments` in `src/app/actions/feed/post.ts`.
  attachments    Json?
  youtubeLinks   String[]
  sourceType     PostSource              @default(USER)
  authorId       String
  communityId    String?
  rssSourceId    String?
  visibility     PostVisibility          @default(PUBLIC)
  commentsCount  Int                     @default(0)
  status         ModerationStatus        @default(APPROVED)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  deletedAt      DateTime?
  slug           String                  @unique
  comments       FeedComment[]
  postReactions  FeedPostReaction[]
  rdgAnnotations FeedPostRdgAnnotation[]
  tagAnnotations FeedPostTagAnnotation[]
  FeedMention    FeedMention[]
  // Required FK → implicit onDelete: Restrict. Post survives account deletion; `eraseUserPersonalData` (AUDIT-20260613-028) anonymizes it in place (content/attachments/youtubeLinks cleared, deletedAt set) rather than cascading.
  author         User                    @relation(fields: [authorId], references: [id])
  community      Community?              @relation(fields: [communityId], references: [id])
  RssSource      RssSource?              @relation(fields: [rssSourceId], references: [id])

  @@index([authorId])
  @@index([communityId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([deletedAt, createdAt])
  @@index([rssSourceId])
  @@index([sourceType])
  @@index([visibility])
}

model FeedPostReaction {
  id        String           @id @default(cuid())
  postId    String
  userId    String
  type      FeedReactionType
  createdAt DateTime         @default(now())
