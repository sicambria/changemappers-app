generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AuditLog {
  id            String      @id @default(cuid())
  userId        String?
  userEmail     String?
  ipAddress     String?
  userAgent     String?
  action        AuditAction
  entityType    String
  entityId      String
  /// Snapshot of the audited entity's fields before the mutation. Free-form `Record<string, unknown>` (the changed entity's columns); redacted via `redactAuditJson` in `src/lib/audit.ts`.
  previousState Json?
  /// Snapshot of the audited entity's fields after the mutation. Same free-form `Record<string, unknown>` shape as `previousState`; redacted via `redactAuditJson`.
  newState      Json?
  /// Free-form audit context (`Record<string, unknown>`), e.g. request/actor details. Written by `createAuditLog` (`src/lib/audit.ts`); redacted before persistence.
  metadata      Json?
  createdAt     DateTime    @default(now())
  // Optional FK; implicit onDelete: SetNull is explicit here. AuditLog survives account deletion; `eraseUserPersonalData` (AUDIT-20260613-028) nulls userId/email/ip/userAgent for GDPR.
  User          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([entityType, entityId])
  @@index([userId, createdAt])
}

model SystemKillSwitch {
  id                      String   @id @default("singleton")
  activityPubEnabled      Boolean  @default(false)
  lanDiscoveryEnabled     Boolean  @default(false)
  externalExportsEnabled  Boolean  @default(false)
  userRegistrationEnabled Boolean  @default(false)
  rssFetchingEnabled      Boolean  @default(false)
  updatedAt               DateTime @updatedAt
}

model BacklogItem {
  id                 String             @id @default(cuid())
  title              String
  description        String
  communityId        String?
  rdgGoal            String?
  domain             String?
  communityResonance Int                @default(0)
  createdById        String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  // Required FK → implicit onDelete: Restrict. Authored backlog item survives account deletion; `eraseUserPersonalData` (AUDIT-20260613-028) anonymizes it in place (title/description scrubbed) rather than cascading.
  createdBy          User               @relation(fields: [createdById], references: [id])
  resonances         BacklogResonance[]

  @@index([communityId])
  @@index([communityResonance])
  @@index([createdById])
}

model BacklogResonance {
  id            String      @id @default(cuid())
  backlogItemId String
  userId        String
  createdAt     DateTime    @default(now())
  backlogItem   BacklogItem @relation(fields: [backlogItemId], references: [id], onDelete: Cascade)
  // Required FK → implicit onDelete: Restrict. Restrict relies on `eraseUserPersonalData` (AUDIT-20260613-028) hard-deleting these resonance rows before user deletion; no cascade declared.
  User          User        @relation(fields: [userId], references: [id])

  @@unique([backlogItemId, userId])
  @@index([backlogItemId])
}

model Board {
  id                String                   @id @default(cuid())
  name              String
  description       String?
  scope             BoardScope               @default(PERSONAL)
  visibility        Visibility               @default(PUBLIC)
  ownerId           String?
  communityId       String?
  bioregion         String?
  country           String?
  /// Per-state work-in-progress caps: `Record<InitiativeState, number | null>`. See `boardSchema.wipLimits` in `src/lib/validations/board.ts`.
  wipLimits         Json?
  /// Ordered column layout: `InitiativeState[]`. See `boardSchema.columns` in `src/lib/validations/board.ts`.
  columns           Json?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  deletedAt         DateTime?
  Community         Community?               @relation(fields: [communityId], references: [id])
  // Optional FK → implicit onDelete: SetNull (board disowned, not deleted, when the owner is removed). `eraseUserPersonalData` (AUDIT-20260613-028) sets ownerId=null + deletedAt.
  User              User?                    @relation(fields: [ownerId], references: [id])
  communityAudience BoardCommunityAudience[]
  initiatives       Initiative[]

  @@index([communityId])
  @@index([ownerId])
  @@index([scope])
  @@index([visibility])
}

model BoardCommunityAudience {
  id          String    @id @default(cuid())
  boardId     String
  communityId String
  createdAt   DateTime  @default(now())
  board       Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([boardId, communityId])
  @@index([communityId])
}

model CanvasNodeComment {
  id                      String              @id @default(cuid())
  nodeId                  String
  parentId                String?
  authorId                String
  content                 String
  createdAt               DateTime            @default(now())
  deletedAt               DateTime?
  // Required FK → implicit onDelete: Restrict. Authored comment survives account deletion; `eraseUserPersonalData` (AUDIT-20260613-028) anonymizes it in place (content → '[deleted]') rather than cascading.
  author                  User                @relation(fields: [authorId], references: [id])
  node                    SystemsCanvasNode   @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  CanvasNodeComment       CanvasNodeComment?  @relation("CanvasNodeCommentToCanvasNodeComment", fields: [parentId], references: [id])
  other_CanvasNodeComment CanvasNodeComment[] @relation("CanvasNodeCommentToCanvasNodeComment")

  @@index([nodeId])
  @@index([parentId])
}

model CoachMeConsent {
  id              String                  @id @default(cuid())
  userId          String                  @unique
  agreedAt        DateTime                @default(now())
  encryptionModel CoachMeEncryptionModel?
  encryptionSalt  String?
  encryptedDek    String?
  User            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CoachMeSession {
  id                     String          @id @default(cuid())
  userId                 String
  focusTag               CoachMeFocusTag
  customFocusTag         String?
  whyImportant           String?
  sessionGoal            String
  sessionSuccessCriteria String?
  miracleSignsA          String?
  miracleSignsB          String?
  miracleSignsC          String?
  miracleOptional        String?
  scalingCurrent         Int?
  scalingAlreadyHere     Int?
  scalingResources       String?
  scalingRecentMoments   String?
  scalingNextStep        String?
  actionPlanV1           String?
  actionPlanFinal        String?
  actionOptional         String?
  sessionUsefulness      Int?
  finalReflections       String?
  currentPhase           Int             @default(0)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  completedAt            DateTime?
  archivedAt             DateTime?
  // Required FK → implicit onDelete: Restrict. Restrict relies on `eraseUserPersonalData` (AUDIT-20260613-028) hard-deleting CoachMe sessions (sensitive coaching content) before user deletion; no cascade declared.
  User                   User            @relation(fields: [userId], references: [id])

  @@index([userId, focusTag])
  @@index([userId])
}

model CoachMeSupportResource {
  id          String  @id @default(cuid())
  region      String  @default("HU")
  name        String
  type        String
  contact     String
  description String?
  order       Int     @default(0)
  active      Boolean @default(true)
}

model CoachingEngagement {
  id            String                   @id @default(cuid())
  offerId       String
  requestId     String
  style         String
  format        String
  arcLength     String
  checkInRhythm String?
  status        CoachingEngagementStatus @default(PENDING)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  completedAt   DateTime?
  offer         CoachingOffer            @relation(fields: [offerId], references: [id])
  request       CoachingRequest          @relation(fields: [requestId], references: [id])
  feedback      CoachingFeedback?

  @@index([offerId])
  @@index([requestId])
  @@index([status])
}

model CoachingFeedback {
  id                 String             @id @default(cuid())
  engagementId       String             @unique
  coacheeReflection  String
  coachObservation   String?
  createdAt          DateTime           @default(now())
  CoachingEngagement CoachingEngagement @relation(fields: [engagementId], references: [id])
}

model CoachingOffer {
  id              String               @id @default(cuid())
  coachId         String
  style           String
  format          String
  arcLengthOption String
  availability    String
  coacheeKnow     String
  isArchived      Boolean              @default(false)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  engagements     CoachingEngagement[]
  // Required FK → implicit onDelete: Restrict. Offer survives account deletion; `eraseUserPersonalData` (AUDIT-20260613-028) anonymizes it in place (coacheeKnow scrubbed, isArchived=true) rather than cascading.
  coach           User                 @relation(fields: [coachId], references: [id])

  @@index([coachId])
  @@index([isArchived])
}

model CoachingRequest {
  id               String               @id @default(cuid())
  requesterId      String
  stuckOn          String
  shiftsWanted     String
  formatPreference String?
  isWithdrawn      Boolean              @default(false)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  engagements      CoachingEngagement[]
  // Required FK → implicit onDelete: Restrict. Request survives account deletion; `eraseUserPersonalData` (AUDIT-20260613-028) anonymizes it in place (stuckOn/shiftsWanted scrubbed, isWithdrawn=true) rather than cascading.
  requester        User                 @relation(fields: [requesterId], references: [id])

  @@index([isWithdrawn])
  @@index([requesterId])
}

model Community {
  id                      String                         @id @default(cuid())
  name                    String
  description             String?
  type                    CommunityType                  @default(OTHER)
  city                    String?
  country                 String?
  region                  String?
  address                 String?
  zipCode                 String?
  latitude                Float?
  longitude               Float?
  foundingYear            Int?
  website                 String?
  acceptingMembers        MembershipStatus               @default(ACCEPTING)
  joiningConditions       String?
  joiningProcess          String?
  governance              String?
  coverImage              String?
  contactEmail            String?
  contactPhone            String?
  contactVisibility       ContactVisibility              @default(MEMBERS_ONLY)
  visibility              Visibility                     @default(PUBLIC)
  verificationLevel       VerificationLevel              @default(SELF_DECLARED)
  seekingVolunteers       Boolean                        @default(false)
  volunteerDescription    String?
  targetMemberDescription String?
  membershipCost          String?
  vision                  String?
  principles              String?
  houseRules              String?
  annualGoals             String?
  createdAt               DateTime                       @default(now())
  updatedAt               DateTime                       @updatedAt
  deletedAt               DateTime?
  ownerId                 String
  moderationStatus        ModerationStatus               @default(APPROVED)
  source                  EntitySource                   @default(USER)
  claimStatus             ClaimStatus                    @default(UNCLAIMED)
  claimRequestById        String?
  Board                   Board[]
  boardAudience           BoardCommunityAudience[]
  // Optional FK → implicit onDelete: SetNull (pending claim request disowned, not deleted, when the claimant is removed). Not separately handled by the erasure helper.
  claimRequestBy          User?                          @relation("Community_claimRequestByIdToUser", fields: [claimRequestById], references: [id])
  // Required FK → implicit onDelete: Restrict. Community is shared content that outlives its owner; NOT handled by `eraseUserPersonalData`, so an erased owner is retained as an anonymized tombstone and the community keeps a valid owner (AUDIT-20260613-028 design point).
  owner                   User                           @relation("Community_ownerIdToUser", fields: [ownerId], references: [id])
  facilities              CommunityFacility[]
  focusAreas              CommunityFocusArea[]
  members                 CommunityMember[]
  values                  CommunityValue[]
  volunteerCapabilities   CommunityVolunteerCapability[]
  Event                   Event[]
  FeedPost                FeedPost[]
  Initiative              Initiative[]
  Appreciate              Appreciate[]
  Pitch                   Pitch[]
  SocialIssue             SocialIssue[]
  socialCauses            SocialCause[]                  @relation("CommunitySocialCauses")
  weakSignals             WeakSignal[]
  signalCommunityLinks    SignalCommunityLink[]

  @@index([acceptingMembers])
  @@index([claimStatus])
  @@index([deletedAt])
  @@index([latitude, longitude])
  @@index([moderationStatus])
  @@index([ownerId])
  @@index([seekingVolunteers])
  @@index([source])
  @@index([type])
  @@index([updatedAt])
  @@index([visibility])
}

model CommunityArchetype {
  id          String  @id @default(cuid())
  title       String  @unique
  slug        String  @unique
  description String?
}

model CommunityFacility {
  id          String    @id @default(cuid())
  communityId String
  facility    String
  Community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, facility])
}

model CommunityFocusArea {
  id          String    @id @default(cuid())
  communityId String
  focusArea   String
  Community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, focusArea])
}

model CommunityHealthSnapshot {
  id                 String   @id @default(cuid())
  communityId        String
  snapshotAt         DateTime @default(now())
  totalActiveMembers Int
  deliveringCount    Int
  buildingCount      Int
  betweenCount       Int
  reflectingCount    Int
  restingCount       Int
  alertTriggered     Boolean  @default(false)

  @@index([alertTriggered])
  @@index([communityId])
  @@index([snapshotAt])
}

model CommunityMember {
  id          String        @id @default(cuid())
  communityId String
  userId      String
  role        CommunityRole @default(MEMBER)
  status      MemberStatus  @default(ACTIVE)
  joinedAt    DateTime      @default(now())
  community   Community     @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
}

model CommunityValue {
  id          String    @id @default(cuid())
  communityId String
  value       String
  Community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, value])
}

model CommunityVolunteerCapability {
  id          String    @id @default(cuid())
  communityId String
  capability  String
  Community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, capability])
}

model CompassProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  northStar         String?
  nonNegotiables    String[]
  originQuestion    String?
  unlockedPillars   String[] @default(["PILLAR_I"])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  bandwidthScore    Int?
  /// Loosely-typed biography section payload (`unknown` in `src/components/features/compass/types.ts`); no Zod schema — caller-defined structure.
  biographyEntries  Json?
  communicationNote String?
  confirmedScope    Int?
  conflictStyleNote String?
  /// Capacity-per-domain map. See `domainBalanceSchema` in `src/lib/validations/compass.ts`.
  domainBalance     Json?
  /// Stakeholder/ecosystem node map. See `ecosystemMapSchema` in `src/lib/validations/compass.ts`.
  ecosystemMap      Json?
  emotionalPattern  String?
  energyPatterns    String?
  /// Array of small experiment objects (max 10). See `experimentSchema` / `experiments` in `src/lib/validations/compass.ts`.
  experiments       Json?
  lastActiveSection String?
  resourceScore     Int?
  riskFears         String?
  storyShift        String?
  storyVision       String?
  storyWhy          String?
  /// Support-network entries. See `supportNetworkSchema` in `src/lib/validations/compass.ts`.
  supportNetwork    Json?
  timeScore         Int?
  /// Translation/reframing map. See `translationMapSchema` in `src/lib/validations/compass.ts`.
  translationMap    Json?
  User              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Connection {
  id          String           @id @default(cuid())
  senderId    String
  receiverId  String
  type        ConnectionType   @default(GENERAL)
  status      ConnectionStatus @default(PENDING)
  message     String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  respondedAt DateTime?
  deletedAt   DateTime?
  receiver    User             @relation("Connection_receiverIdToUser", fields: [receiverId], references: [id], onDelete: Cascade)
  sender      User             @relation("Connection_senderIdToUser", fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId])
  @@index([status])
}

model ContributionConnection {
  id          String                       @id @default(cuid())
  offerId     String
  requestId   String
  status      ContributionConnectionStatus @default(PENDING)
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt
  completedAt DateTime?
  offer       ContributionOffer            @relation(fields: [offerId], references: [id])
  request     ContributionRequest          @relation(fields: [requestId], references: [id])
  feedback    ContributionFeedback?

  @@index([offerId])
  @@index([requestId])
  @@index([status])
}

model ContributionFeedback {
  id               String                 @id @default(cuid())
  connectionId     String                 @unique
  publicReflection String
  createdAt        DateTime               @default(now())
  connection       ContributionConnection @relation(fields: [connectionId], references: [id])
}

model ContributionOffer {
  id             String                   @id @default(cuid())
  offererId      String
  type           ContributionType
  domain         String?
  timeCommitment String
  format         String
  availability   String
  prerequisites  String?
  isArchived     Boolean                  @default(false)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  connections    ContributionConnection[]
  // Required FK → implicit onDelete: Restrict. Offer survives account deletion; `eraseUserPersonalData` (AUDIT-20260613-028) anonymizes it in place (prerequisites nulled, isArchived=true) rather than cascading.
  offerer        User                     @relation(fields: [offererId], references: [id])

  @@index([isArchived])
  @@index([offererId])
  @@index([type])
}

model ContributionRequest {
  id           String                   @id @default(cuid())
  requesterId  String
  type         ContributionType
  whatNeeded   String
  alreadyTried String?
  willDoWith   String?
  isWithdrawn  Boolean                  @default(false)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  connections  ContributionConnection[]
  // Required FK → implicit onDelete: Restrict. Request survives account deletion; `eraseUserPersonalData` (AUDIT-20260613-028) anonymizes it in place (whatNeeded/alreadyTried/willDoWith scrubbed, isWithdrawn=true) rather than cascading.
  requester    User                     @relation(fields: [requesterId], references: [id])

  @@index([isWithdrawn])
  @@index([requesterId])
  @@index([type])
}

model EnergyCanvas {
  id             String            @id @default(cuid())
  title          String
  description    String?
  systemState    EnergySystemState @default(CONTESTED)
  stateReason    String?
  privacy        EnergyPrivacy     @default(ONLY_ME)
  communityId    String?
  createdById    String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  // Required FK → implicit onDelete: Restrict. Canvas survives account deletion; `eraseUserPersonalData` (AUDIT-20260613-028) anonymizes it in place (description/stateReason nulled, deletedAt set) rather than cascading.
  createdBy      User              @relation(fields: [createdById], references: [id])
  entities       EnergyEntity[]
  relations      EnergyRelation[]
  EnergySnapshot EnergySnapshot[]

  @@index([communityId])
  @@index([createdById])
  @@index([deletedAt])
  @@index([privacy])
}

model EnergyEntity {
  id                                                       String               @id @default(cuid())
  canvasId                                                 String
  roleLabel                                                String
  entityType                                               EnergyEntityType
  primaryScale                                             EnergyScale
  multiScale                                               EnergyScale[]
  visibility                                               EntityVisibility     @default(VISIBLE)
  energyState                                              EnergyState
  energyMagnitude                                          EnergyMagnitude      @default(MEDIUM)
  energyRate                                               EnergyRate           @default(CHRONIC)
  internalPower                                            InternalPower        @default(DISTRIBUTED)
  numericValue                                             Float?
  numericUnit                                              String?
  voiceAccess                                              VoiceAccess          @default(FULL)
  boundaryPermeability                                     BoundaryPermeability @default(SEMI_PERMEABLE)
  selfDetermination                                        SelfDetermination    @default(PRESENT)
  positionX                                                Int                  @default(0)
  positionY                                                Int                  @default(0)
  scaleBandY                                               Int                  @default(4)
  notes                                                    String?
  uncertaintyFlag                                          Boolean              @default(false)
  createdById                                              String
  createdAt                                                DateTime             @default(now())
  updatedAt                                                DateTime             @updatedAt
  deletedAt                                                DateTime?
  widgetContent                                            String?
  EnergyCanvas                                             EnergyCanvas         @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  // Required FK → implicit onDelete: Restrict. Entity survives account deletion; `eraseUserPersonalData` (AUDIT-20260613-028) anonymizes it in place (roleLabel/notes/widgetContent scrubbed, deletedAt set) rather than cascading.
  User                                                     User                 @relation(fields: [createdById], references: [id])
  EnergyRelation_EnergyRelation_fromEntityIdToEnergyEntity EnergyRelation[]     @relation("EnergyRelation_fromEntityIdToEnergyEntity")
  EnergyRelation_EnergyRelation_toEntityIdToEnergyEntity   EnergyRelation[]     @relation("EnergyRelation_toEntityIdToEnergyEntity")
  EntityDataPoint                                          EntityDataPoint[]

  @@index([canvasId])
  @@index([deletedAt])
  @@index([entityType])
  @@index([primaryScale])
}

model EnergyPatternEntry {
  id                   String               @id @default(cuid())
  name                 String
  category             String
  definition           String
  /// Structural fingerprint of the pattern: `Record<string, unknown>` (caller-defined). See `proposeEnergyPatternSchema.structuralSignature` in `src/lib/validations/energy.ts`.
  structuralSignature  Json
  mechanismDescription String
  leveragePoints       String[]
  realWorldExamples    String
  status               PatternStatus        @default(PROPOSED)
  proposedById         String
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  // Required FK → implicit onDelete: Restrict. Pattern entry survives account deletion; `eraseUserPersonalData` (AUDIT-20260613-028) anonymizes it in place (definition/mechanism/examples scrubbed, status=RETIRED) rather than cascading.
  proposedBy           User                 @relation(fields: [proposedById], references: [id])
  EnergyPatternMatch   EnergyPatternMatch[]

  @@index([category])
  @@index([status])
}

model EnergyPatternMatch {
  id                 String             @id @default(cuid())
  canvasId           String
  patternId          String
  confidence         PatternConfidence
  matchedEntities    String[]
  matchedRelations   String[]
  detectedAt         DateTime           @default(now())
  EnergyPatternEntry EnergyPatternEntry @relation(fields: [patternId], references: [id])

  @@index([canvasId])
  @@index([patternId])
}

model EnergyRelation {
  id                                                     String              @id @default(cuid())
  canvasId                                               String
  fromEntityId                                           String
  toEntityId                                             String
  powerDistance                                          PowerDistance
  energyFlow                                             EnergyFlowType
  informationFlow                                        InformationFlowType
  visibility                                             RelationVisibility  @default(VISIBLE)
  consent                                                RelationConsent
  energyMagnitude                                        EnergyMagnitude     @default(MEDIUM)
  numericValue                                           Float?
  numericUnit                                            String?
  isCrossScale                                           Boolean             @default(false)
  patternDetected                                        String?
  notes                                                  String?
  uncertaintyFlag                                        Boolean             @default(false)
  createdById                                            String
  createdAt                                              DateTime            @default(now())
  updatedAt                                              DateTime            @updatedAt
  deletedAt                                              DateTime?
  EnergyCanvas                                           EnergyCanvas        @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  // Required FK → implicit onDelete: Restrict. Relation survives account deletion; `eraseUserPersonalData` (AUDIT-20260613-028) anonymizes it in place (notes/patternDetected nulled, deletedAt set) rather than cascading.
  User                                                   User                @relation(fields: [createdById], references: [id])
  EnergyEntity_EnergyRelation_fromEntityIdToEnergyEntity EnergyEntity        @relation("EnergyRelation_fromEntityIdToEnergyEntity", fields: [fromEntityId], references: [id])
  EnergyEntity_EnergyRelation_toEntityIdToEnergyEntity   EnergyEntity        @relation("EnergyRelation_toEntityIdToEnergyEntity", fields: [toEntityId], references: [id])

  @@index([canvasId])
  @@index([deletedAt])
  @@index([fromEntityId])
  @@index([toEntityId])
}

model EnergySnapshot {
  id           String       @id @default(cuid())
  canvasId     String
  name         String
  timestamp    DateTime     @default(now())
  /// Full serialized EnergyCanvas state at snapshot time (the canvas with its entities/relations). Written from the canvas object in `createEnergySnapshotAction` (`src/app/actions/energy/export.ts`); not separately validated.
  data         Json
  createdBy    String
  createdAt    DateTime     @default(now())
  EnergyCanvas EnergyCanvas @relation(fields: [canvasId], references: [id], onDelete: Cascade)

  @@index([canvasId])
}

model EntityDataPoint {
  id            String       @id @default(cuid())
  entityId      String
  submittedBy   String
  submittedAt   DateTime     @default(now())
  value         Float
  isQualitative Boolean      @default(false)
  source        String?
  EnergyEntity  EnergyEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
}

model Event {
  id                      String           @id @default(cuid())
  title                   String
  description             String?
  startDate               DateTime
  endDate                 DateTime?
  isAllDay                Boolean          @default(false)
  timezone                String           @default("Europe/Budapest")
  isOnline                Boolean          @default(false)
  onlineLink              String?
  location                String?
  address                 String?
  latitude                Float?
  longitude               Float?
  type                    EventType        @default(PUBLIC)
  category                EventCategory    @default(MEETUP)
  capacity                Int?
  registrationRequired    Boolean          @default(false)
  costType                CostType         @default(FREE)
  costAmount              Float?
  costCurrency            String?          @default("HUF")
  coverImage              String?
  facebookEventUrl        String?
  status                  EventStatus      @default(UPCOMING)
  isRecurring             Boolean          @default(false)
  recurrenceRule          String?
  parentEventId           String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  deletedAt               DateTime?
  hostId                  String
  communityId             String?
  moderationStatus        ModerationStatus @default(APPROVED)
  source                  EntitySource     @default(USER)
  claimStatus             ClaimStatus      @default(UNCLAIMED)
  claimRequestById        String?
  // Optional FK → implicit onDelete: SetNull (pending claim request disowned, not deleted, when the claimant is removed). Not separately handled by the erasure helper.
  claimRequestBy          User?            @relation("Event_claimRequestByIdToUser", fields: [claimRequestById], references: [id])
  Community               Community?       @relation(fields: [communityId], references: [id])
  // Required FK → implicit onDelete: Restrict. Event survives account deletion; `eraseUserPersonalData` (AUDIT-20260613-028) anonymizes it in place (description/address/links/location nulled, deletedAt set) rather than cascading.
  User_Event_hostIdToUser User             @relation("Event_hostIdToUser", fields: [hostId], references: [id])
  Event                   Event?           @relation("EventToEvent", fields: [parentEventId], references: [id])
  other_Event             Event[]          @relation("EventToEvent")
  EventRsvp               EventRsvp[]
  organizers              EventOrganizer[]
  socialCauses            EventSocialCause[]
  rdgTags                 EventRdgTag[]
  Appreciate              Appreciate[]

  @@index([claimStatus])
  @@index([communityId])
  @@index([hostId])
  @@index([latitude, longitude])
  @@index([moderationStatus])
  @@index([parentEventId])
  @@index([deletedAt, type, moderationStatus, status, startDate])
  @@index([source])
  @@index([startDate])
  @@index([status])
  @@index([type])
  @@index([updatedAt])
}

model EventRsvp {
