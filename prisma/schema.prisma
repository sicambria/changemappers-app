  createdById    String
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  completedAt    DateTime?
  archivedAt     DateTime?
  archiveReason  String?
  assigneeId     String?
  boardId        String?
  // Optional FK → implicit onDelete: SetNull (initiative unassigned, not deleted, when the assignee is removed). `eraseUserPersonalData` (AUDIT-20260613-028) sets assigneeId=null.
  assignee       User?                    @relation("Initiative_assigneeIdToUser", fields: [assigneeId], references: [id])
  Board          Board?                   @relation(fields: [boardId], references: [id])
  Community      Community?               @relation(fields: [communityId], references: [id])
  // Required FK → implicit onDelete: Restrict. Initiative survives account deletion; `eraseUserPersonalData` (AUDIT-20260613-028) anonymizes it in place (description/why scrubbed, archivedAt set) rather than cascading.
  createdBy      User                     @relation("Initiative_createdByIdToUser", fields: [createdById], references: [id])
  retrospective  InitiativeRetrospective?
  roles          InitiativeRole[]
  updates        InitiativeUpdate[]
  Pitch          Pitch?
  metrics        TaskMetric?

  @@index([assigneeId])
  @@index([boardId])
  @@index([communityId])
  @@index([createdById])
  @@index([initiativeType])
  @@index([state])
}

