  metadata     Json
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  // Optional FK with explicit onDelete: SetNull. Feedback is retained for product analytics after account deletion; `eraseUserPersonalData` (AUDIT-20260613-028) nulls userId + scrubs free-text/metadata for GDPR.
  User         User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  // Optional 1:1 back-relation: a Feedback may be published as a public IdeaPost (FK lives on IdeaPost.feedbackId).
  ideaPost     IdeaPost?

  @@index([status])
  @@index([userId])
}

enum IdeaPostType {
  PAIN_POINT
  FEATURE_IDEA
  BUG_FIX
}

enum IdeaPostStatus {
  OPEN
  PLANNED
  IN_PROGRESS
  DONE
  DECLINED
}

/// Public community idea/pain-point/feature request, optionally published from a private Feedback. Visible to registered (non-guest) users only (auth-gated in the action layer). GDPR: createdBy is scrub-retained on erasure (like Story/Initiative).
model IdeaPost {
  id          String         @id @default(cuid())
  title       String
  description String
  type        IdeaPostType
  status      IdeaPostStatus @default(OPEN)
  /// Canonical RDG ids (RDG01..RDG30) from src/lib/taxonomy; validated with assertCanonicalRdgIds.
  rdgTags     String[]
  tags        String[]
  /// Denormalized upvote counter (precedent: BacklogItem.communityResonance). Erasure does not reconcile it (matches BacklogResonance).
  voteCount   Int            @default(0)
  feedbackId  String?        @unique
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  feedback    Feedback?      @relation(fields: [feedbackId], references: [id], onDelete: SetNull)
  // Required FK → implicit onDelete: Restrict. Restrict relies on `eraseUserPersonalData` scrubbing IdeaPost title/description in place (user row is anonymized, not deleted); no cascade.
  createdBy   User           @relation(fields: [createdById], references: [id])
  votes       IdeaVote[]
  comments    IdeaComment[]

  @@index([status])
  @@index([type])
  @@index([voteCount])
  @@index([createdById])
}

/// One upvote per user per IdeaPost (toggleable). GDPR: deleted on erasure (like BacklogResonance/SignalResonanceVote).
model IdeaVote {
  id         String   @id @default(cuid())
  ideaPostId String
  userId     String
  createdAt  DateTime @default(now())
  ideaPost   IdeaPost @relation(fields: [ideaPostId], references: [id], onDelete: Cascade)
  // Required FK → implicit onDelete: Restrict. Restrict relies on `eraseUserPersonalData` deleting these rows before user deletion; no cascade declared.
  user       User     @relation(fields: [userId], references: [id])

  @@unique([ideaPostId, userId])
  @@index([ideaPostId])
  @@index([userId])
}

/// Comment on a public IdeaPost. GDPR: content scrubbed in place on erasure (like StoryComment/FeedComment).
model IdeaComment {
  id         String   @id @default(cuid())
  ideaPostId String
  userId     String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  ideaPost   IdeaPost @relation(fields: [ideaPostId], references: [id], onDelete: Cascade)
  // Required FK → implicit onDelete: Restrict. Restrict relies on `eraseUserPersonalData` scrubbing content in place; no cascade.
  user       User     @relation(fields: [userId], references: [id])

  @@index([ideaPostId])
  @@index([userId])
}

model Initiative {
