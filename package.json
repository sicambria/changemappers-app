  "scripts": {
    "dev": "npm run dev:prep && node scripts/dev/dev.js",
    "dev:prep": "node scripts/dev/check-env.js && npm run db:migrate:deploy && npm run db:generate && node scripts/dev/generate-routes-json.mjs",
    "dev:full": "npm run dev:prep && node scripts/dev/dev.js",
    "build": "node scripts/dev/with-perf.mjs --seq \"npm run cleanup\" \"node scripts/dev/clean-next-dev-types.js\" \"npm run build:prep\" \"cross-env NODE_ENV=production next build\"",
    "build:prep": "node scripts/dev/check-env.js && npm run db:generate",
    "start": "next start",
    "prod": "next start",
    "prod:full": "npm run build && npm run start",
    "prod:local": "cross-env SKIP_PROD_CHECKS=1 npm run prod:full",
    "db:generate": "prisma generate",
    "db:migrate": "node scripts/db/run-prisma-with-migration-url.mjs migrate dev",
    "db:migrate:deploy": "node scripts/db/run-prisma-with-migration-url.mjs migrate deploy",
    "db:reset": "node scripts/db/run-prisma-with-migration-url.mjs migrate reset --force",
    "db:push": "prisma db push && prisma generate",
    "db:studio": "prisma studio",
    "lint": "eslint --max-warnings 0",
    "typecheck": "node scripts/dev/clean-next-dev-types.js && node --max-old-space-size=4096 node_modules/typescript/lib/tsc.js --noEmit",
    "cleanup": "node scripts/ops/cleanup.js",
    "reset:hard": "rimraf node_modules .next .turbo src/generated/prisma && npm ci && npm run db:generate",
    "health": "node scripts/diagnostics/health-check.js",
    "postinstall": "prisma generate"
  },
