# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/all_tests_output*.txt
/verification_results*.txt
/e2e_test_output.txt
/compass_out.txt
/interactions_out.txt
/lint-results-*.txt
/routes.json
/seed_error.txt
/test_output.txt
/tsc_errors*.txt
/playwright-report-prod-vps/
/test-results/
/e2e-diagnostics/
e2e_output.txt
e2e_errors.txt
# Playwright saved auth storage state — generated by e2e/auth.setup.ts, never committed
/.auth/
# E2E monitoring artifacts
/docs/e2e-monitoring/
/docs/audits/e2e-monitoring/

# next.js
/.next/
/.next-cache/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit real secrets
.env
.env.local
.env.*.local
# .env.example is intentionally tracked (safe template, no secrets)
!.env.example
!.env.enc

# vercel
.vercel


# typescript
*.tsbuildinfo
.tsbuildinfo/
next-env.d.ts

/src/generated/prisma

# LikeC4 generated artifacts (source of truth is docs/architecture/c4/model/*.c4)
/docs/architecture/c4/generated/
/docs/architecture/c4/exports/

# logs
*.log
*_log.txt
build_log*.txt
seed_log*.txt
seed_error*.log
test_log*.txt

# Invites
invites.json
invites.md

# Temporary / one-off scripts and artifact files — never commit these
/tmp/
/.turbo/
/.cache/
/.cache-loader/
/.nx/
/.coverage/
/.stryker-tmp/
/reports/mutation/
/.coverage_tmp/
/coverage_tmp/
/.coverage-output/
/coverage-output/
tmp-*.ts
tmp-*.js
update-auth*.js
update-auth*.cjs
all.diff
staged.diff
tsc_errors*.txt
eslint-errors*.txt
stackver.txt
project_config_dump.txt
# AI-related files
CLAUDE.md
.claude/
.antigravity/worktrees/
.antigravity/lean-runs/
.antigravity/workflow-evidence/
.kilo/
.opencode/
.scannerwork/
*.txt
*.log
!docs/**/*.md
# Generated major-test reports; keep the folder README as the tracked contract.
/docs/testing/major/**
!/docs/testing/major/README.md
/scratch/

# Sentry Config File
.env.sentry-build-plugin

# LaTeX paper build artifacts (build-pdf.sh intermediates; PDF itself is tracked)
docs/meta/papers/*/build/

# Pre-push run logs (post-mortem diagnosability) and local flakiness-detector output.
# Local-only artifacts; never committed. See .husky/pre-push and
# scripts/testing/detect-vitest-order-flakiness.mjs.
/.prepush-logs/
/.flake-runs/

# Android signing — NEVER commit a plaintext keystore or its passwords.
# The release identity is committed ONLY as secrets/android-signing.env.enc (SOPS).
# See docs/operations/android-apk-build.md.
*.jks
*.keystore
*.p12
*.pfx
android/keystore.properties
android/local.properties
