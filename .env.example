# =============================================================================
# Changemappers — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# CHANGEMAPPERS CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
# SECURITY NOTE: Plain text .env files are 70/100 security.
# For 90-100/100, use a Secret Manager. Cheapest options:
# 1. Mozilla SOPS (Free) - Encrypts secrets for Git using AGE/PGP.
# 2. Infisical (Self-hosted) - UI-based secret management.
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit your .env file — it is already in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# PostgreSQL owner password for the local Compose database bootstrap/migration role.
DB_PASSWORD="replace-with-a-long-random-owner-password"

# Separate runtime/backup role passwords used by docker/postgres/init/001-role-separation.sh on first DB initialization.
APP_DB_PASSWORD="replace-with-a-long-random-app-role-password"
BACKUP_DB_PASSWORD="replace-with-a-long-random-backup-role-password"

# PostgreSQL port is per-host — set it to match your local DB workflow:
#   5432  native system PostgreSQL  (roles set up by: sudo bash scripts/ops/setup-local-db.sh)
#   5433  Docker container          (roles set up by Docker init scripts in docker/postgres/init/)
# Change the port in all three URLs below to switch between the two workflows.

# PostgreSQL connection URL (Prisma format). In production this should be the limited app role.
DATABASE_URL="postgresql://changemappers_app:APP_DB_PASSWORD@db:5432/changemappers"

# Prisma migrations/deploys should use a DDL-capable migration/owner role.
MIGRATION_DATABASE_URL="postgresql://changemappers:DB_PASSWORD@127.0.0.1:5432/changemappers"

# Backup worker should use a read-only backup role.
BACKUP_DATABASE_URL="postgresql://changemappers_backup:BACKUP_DB_PASSWORD@db:5432/changemappers"

# Plaintext database backups are disabled unless this is intentionally set to 1 for local/operator-only runs.
ALLOW_PLAINTEXT_BACKUPS="0"

# -----------------------------------------------------------------------------
# Authentication — JWT
# Generate strong random secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# -----------------------------------------------------------------------------
JWT_SECRET="replace-with-a-long-random-secret"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-secret"
LEAN_REG_SIGNING_SECRET="replace-with-a-different-long-random-secret-for-lean-registration"

# Separate secret for deriving video room names (do not reuse JWT_SECRET - key separation).
VIDEO_ROOM_HMAC_SECRET="replace-with-a-different-long-random-secret-for-video-rooms"


# Encrypts direct messages at rest so a database dump does not expose private message plaintext.
HIGH_RISK_CONTENT_ENCRYPTION_KEY="replace-with-a-long-random-secret-for-private-content-encryption"

# Encrypts TOTP 2FA secrets at rest (do not reuse JWT_SECRET / other keys - key separation).
# Required to enable two-factor auth; the TOTP crypto helper fails closed without it.
TOTP_ENCRYPTION_KEY="replace-with-a-different-long-random-secret-for-totp-encryption"
# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV="development"

# Base URL of the application (used for OAuth redirect URIs and magic link URLs)
# Development: http://localhost:3000  |  Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_ENABLE_SOCKET_CHAT="false"

# Socket.IO server origin allowed by CORS (must match the deployed frontend URL in production)
# Development default: http://localhost:3000
NEXT_PUBLIC_SOCKET_URL="http://localhost:3000"
SOCKET_CORS_ORIGIN="http://localhost:3000"


# -----------------------------------------------------------------------------
# Email — Multi-Provider Support
# Choose your email provider: local (dev), resend, brevo, or mailgun
# In production, use resend (default), brevo, or mailgun
# -----------------------------------------------------------------------------
EMAIL_PROVIDER=local
EMAIL_DEBUG=false

# SMTP / Mailpit local capture values. To use Mailpit locally or on a controlled VPS test,
# set EMAIL_PROVIDER=smtp and point SMTP_HOST/SMTP_PORT at the Mailpit SMTP listener.
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
MAILPIT_MAX_MESSAGES=500

# Global sender email address (used by all providers)
# Backward compatible: RESEND_FROM_EMAIL still works, but EMAIL_FROM_EMAIL takes precedence
EMAIL_FROM_EMAIL="noreply@changemappers.com"

# Resend (https://resend.com) - free tier: 3,000 emails/month
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@changemappers.com"

# Brevo (formerly Sendinblue) - https://www.brevo.com
BREVO_API_KEY=""
# Production Brevo guard: set this to the exact sender/domain identity that is active in Brevo.
# Startup validation fails when EMAIL_PROVIDER=brevo and EMAIL_FROM_EMAIL does not match it.
BREVO_VERIFIED_SENDER_EMAIL=""

# Mailgun - https://www.mailgun.com
MAILGUN_API_KEY=""
MAILGUN_DOMAIN="changemappers.com"

# -----------------------------------------------------------------------------
# Cron Job Security
# Protects scheduled job endpoints (/api/cron/*) from unauthorized invocation.
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set this same value as the Authorization Bearer token in your cron scheduler (Vercel Cron, etc.)
# -----------------------------------------------------------------------------
CRON_SECRET="replace-with-a-strong-random-secret"

# -----------------------------------------------------------------------------
# Backups
# Used by the docker-compose backup worker, which runs pg_dump daily at 02:00 UTC by default.
# -----------------------------------------------------------------------------
S3_BACKUP_BUCKET="changemappers-backups"
AWS_REGION="eu-central-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_TOKEN=""
BACKUP_CRON_SCHEDULE="0 2 * * *"
PENDING_REGISTRATION_CRON_SCHEDULE="15 3 * * *"
APP_CRON_BASE_URL="http://host.docker.internal:3000"
BACKUP_RETAIN_DAYS="30"
BACKUP_PUBLIC_KEY=""        # Optional: Age public key for client-side encryption (starts with age1...)
SENTRY_BACKUP_CRON_CHECKIN_URL=""
SENTRY_HOOK_URL=""
USER_FILES_DIRS="public/uploads:uploads:user-files"
USER_FILES_BACKUP_DIR="/tmp/changemappers-user-file-backups"
USER_FILES_RCLONE_REMOTE="gdrive-backups:changemappers/user-files"
USER_FILES_RETAIN_DAYS="30"

# -----------------------------------------------------------------------------
# Rate Limiting
# Use RATE_LIMIT_PROVIDER=upstash for shared limits. Use memory only for an
# explicitly single-node deployment where shared Redis is unavailable.
RATE_LIMIT_PROVIDER="upstash"
APP_INSTANCE_COUNT="1"

# Reverse proxy contract: set TRUST_PROXY_HEADERS=1 only when the edge proxy
# strips untrusted client-supplied X-Forwarded-For/X-Real-IP and then appends
# the real client address. When unset, the app ignores forwarded IP headers.
TRUST_PROXY_HEADERS="1"

# Rate Limiting — Upstash Redis (recommended for multi-instance / production)
# Without these vars the rate limiter falls back to an in-process Map, which
# means each serverless instance has its own counter. On multi-replica
# deployments the effective limit is (limit × replica_count).
# Get a free Redis instance at https://upstash.com
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# -----------------------------------------------------------------------------
# Monitoring — Sentry (optional)
# Obtain DSN from https://sentry.io after creating a project
# Use SENTRY_DSN (preferred): Sentry's Next.js SDK injects it at build time,
# so it works for client-side error reporting without exposing the DSN in
# the public JS bundle via a NEXT_PUBLIC_ variable.
# NEXT_PUBLIC_SENTRY_DSN is still accepted as a fallback for legacy deployments.
# -----------------------------------------------------------------------------
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE="0.1"
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0"
# NEXT_PUBLIC_SENTRY_DSN=""  # Legacy fallback only — prefer SENTRY_DSN above

# -----------------------------------------------------------------------------
# Logging
# Pino log level: trace | debug | info | warn | error | fatal
# -----------------------------------------------------------------------------
LOG_LEVEL="info"

# -----------------------------------------------------------------------------
# SonarQube — local code-quality scan (optional; only for `npm run sonar`)
# Install the scanner CLI with: ./scripts/dev/setup-dev-env.sh --with-sonar
# Generate a token at http://localhost:9000/account/security and paste it below.
# `npm run sonar` and the pre-push Sonar gate self-load these from .env, so no
# manual `export` is needed once they are set here. Leave empty to fall back to
# the admin:admin convention (fails if the local admin password was rotated).
# Coverage on the dashboard requires a fresh report — run `npm run test:coverage`
# before `npm run sonar` (the scan imports coverage/lcov.info).
# -----------------------------------------------------------------------------
SONAR_TOKEN=""
SONAR_HOST_URL="http://localhost:9000"

# -----------------------------------------------------------------------------
# E2E Testing
# NODE_ENV=test is set automatically by the test runner (Jest/Playwright CI).
# Do NOT set it here — having two NODE_ENV entries in .env is confusing and
# the second value is ignored by most loaders anyway.
# Credentials for the primary and secondary seeded test users.
# E2E_CLEANUP_SECRET protects the POST /api/test/cleanup endpoint.
#
# SECURITY: Change E2E_TEST_PASSWORD and E2E_TEST_PASSWORD_2 before seeding
# any shared or staging environment. The default "TestPassword123!" is a
# publicly known value — any user with repo access can authenticate as these
# test accounts if the default is left unchanged in a shared database.
# Generate a strong random value: openssl rand -base64 24
# -----------------------------------------------------------------------------
E2E_TEST_EMAIL="test@changemappers.hu"
E2E_TEST_PASSWORD="TestPassword123!"
E2E_TEST_EMAIL_2="gazda@changemappers.hu"
E2E_TEST_PASSWORD_2="TestPassword123!"
E2E_CLEANUP_SECRET="replace-with-a-strong-random-secret"
