    "/api/gdpr/export": {
      "get": {
        "description": "Returns the full GDPR data export for the authenticated user as a JSON download. Rate-limited to at most twice per day.",
        "responses": {
          "200": {
            "description": "GDPR data export (JSON attachment)"
          },
          "401": {
            "description": "Unauthorized — no valid session"
          },
          "404": {
            "description": "Authenticated user not found"
          },
          "429": {
            "description": "Rate limit exceeded (max twice per day)"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "summary": "Export user data (GDPR)"
      }
    },
    "/api/health": {
      "get": {
        "description": "Returns the application's liveness/readiness, including a database connectivity probe.",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "status": {
                      "example": "ok",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Service is healthy"
          },
          "503": {
            "description": "Service unhealthy (e.g. database disconnected) — body { status: \"error\" }"
          }
        },
        "summary": "Health Check"
      }
    },
